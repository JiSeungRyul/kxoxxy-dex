{
  "name": "kxoxxy-dex",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "node --import ./tests/register-paths.mjs --experimental-strip-types --experimental-test-module-mocks --test tests/**/*.test.mjs",
    "typecheck": "tsc --noEmit",
    "sync:pokedex": "node scripts/sync-pokedex.mjs",
    "sync:items": "node scripts/sync-items.mjs",
    "sync:moves": "node scripts/sync-moves.mjs",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:seed:pokedex": "node scripts/import-pokedex-to-db.mjs",
    "db:seed:items": "node scripts/import-items-to-db.mjs",
    "db:seed:moves": "node scripts/sync-moves.mjs && node scripts/import-moves-to-db.mjs"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.1",
    "next": "^15.0.0",
    "postgres": "^3.4.8",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.20",
    "dotenv": "^17.3.1",
    "drizzle-kit": "^0.31.9",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.0"
  }
}
